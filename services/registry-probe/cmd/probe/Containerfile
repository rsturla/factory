FROM quay.io/hummingbird/go:1.26 AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -tags containers_image_openpgp -o /probe ./cmd/probe

FROM quay.io/hummingbird/core-runtime:latest
COPY --from=builder /probe /usr/local/bin/probe
ENV LISTEN_ADDR=:8080
EXPOSE 8080
ENTRYPOINT ["probe"]
