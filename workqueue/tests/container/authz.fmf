summary: Authorization integration tests (Cedar)
description: |
    Tests Cedar policy enforcement on pre-built container images.
    Verifies SRE full access, team-scoped access, read-only for
    authenticated users, and denial for unauthenticated requests.
test: bash tests/container/run-authz.sh
duration: 10m
require:
    - docker
    - docker-compose
    - curl
    - python3
framework: shell

adjust+:
  - when: initiator == konflux
    enabled: true
  - when: initiator != konflux
    enabled: false
