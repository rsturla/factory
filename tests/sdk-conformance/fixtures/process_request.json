{
  "tests": [
    {
      "name": "full_request",
      "json": {"key": "curl-8.7.1-2.fc43", "attempt": 3, "priority": 10, "trace_id": "00-abc123-def456-01"},
      "expected": {
        "key": "curl-8.7.1-2.fc43",
        "attempt": 3,
        "priority": 10,
        "trace_id": "00-abc123-def456-01"
      }
    },
    {
      "name": "minimal_request",
      "json": {"key": "pkg-1.0"},
      "expected": {
        "key": "pkg-1.0",
        "attempt": 0,
        "priority": 0,
        "trace_id": ""
      }
    },
    {
      "name": "zero_attempt",
      "json": {"key": "k", "attempt": 0, "priority": 0},
      "expected": {
        "key": "k",
        "attempt": 0,
        "priority": 0,
        "trace_id": ""
      }
    }
  ]
}
